ub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}sub{}s